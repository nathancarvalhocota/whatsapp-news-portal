# URL da API back-end (ASP.NET Core)
# Em desenvolvimento: http://localhost:5074
# Em produção (Render): https://<seu-servico>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5074

# URL pública do site (para SEO: canonical, sitemap, OG)
# Em produção (Vercel): https://seu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Senha de acesso à página /admin (server-side, NÃO usar NEXT_PUBLIC)
ADMIN_SECRET=hackathon2025
